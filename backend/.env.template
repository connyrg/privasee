# PrivaSee Backend — environment variable template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ---------------------------------------------------------------------------
# Databricks connectivity
# ---------------------------------------------------------------------------

DATABRICKS_HOST=           # your Databricks workspace URL, e.g. https://adb-xxxx.azuredatabricks.net
DATABRICKS_TOKEN=          # personal access token with UC Files API and Model Serving permissions

# ---------------------------------------------------------------------------
# Databricks Model Serving
# ---------------------------------------------------------------------------

DATABRICKS_MODEL_ENDPOINT= # full URL of the document intelligence Model Serving endpoint
                           # e.g. https://adb-xxxx.azuredatabricks.net/serving-endpoints/privasee-di/invocations

DATABRICKS_MASKING_ENDPOINT= # full URL of the masking Model Serving endpoint
                              # e.g. https://adb-xxxx.azuredatabricks.net/serving-endpoints/privasee-masking/invocations

# ---------------------------------------------------------------------------
# Unity Catalog volume (session state storage)
# ---------------------------------------------------------------------------

UC_VOLUME_PATH=            # base path for session artefacts
                           # e.g. /Volumes/my_catalog/my_schema/privasee_sessions

# ---------------------------------------------------------------------------
# CORS (Posit Connect deployment)
# ---------------------------------------------------------------------------

ALLOWED_ORIGINS=           # comma-separated list of allowed origins
                           # e.g. https://connect.example.com,http://localhost:5173
