# PrivaSee .gitignore

# --- Environment files (NEVER commit secrets) ---
.env
.env.*
!.env.template

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
*.cover

# --- Node / frontend ---
node_modules/
frontend/dist/
frontend/.vite/

# --- Databricks ---
.databricks/
*.dbc

# --- Posit Connect ---
*/rsconnect-python/*

# --- OS / editor ---
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# --- Data directories (runtime artefacts, not source) ---
backend/data/
data/

# backend/static/ is intentionally tracked — it holds the pre-built React bundle
# committed by the build-frontend.yml CI workflow so Posit Connect deployments
# do not require Node.js in the deployment environment.
