# PrivaSee .gitignore

# --- Environment files (NEVER commit secrets) ---
.env
.env.*
!.env.template

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
*.cover

# --- Node / frontend ---
node_modules/
frontend/dist/
frontend/.vite/

# --- Databricks ---
.databricks/
*.dbc

# --- OS / editor ---
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# --- Data directories (runtime artefacts, not source) ---
backend/data/
data/

# --- CI-generated frontend build (copied into backend before Posit Connect deploy) ---
backend/static/
